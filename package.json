{
  "name": "game-guide",
  "version": "1.0.0",
  "description": "PDF/CBZ reader web app for legacy iPad, served over LAN",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "dev:clean": "rm -rf data && node --watch server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run format:check && npm run lint && npm run test",
    "prepare": "husky"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cookie-parser": "^1.4.6",
    "express": "^4.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.33.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "eslint-plugin-es-x": "^9.5.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "vitest": "^4.0.18"
  }
}
